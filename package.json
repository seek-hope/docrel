{
  "name": "doc-relay",
  "version": "0.1.1",
  "description": "Forge and maintain living connections between code symbols and documentation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "doc-relay": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod 755 dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "simple-git": "^3.0.0",
    "yaml": "^2.0.0",
    "zod": "^4.4.3"
  },
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
